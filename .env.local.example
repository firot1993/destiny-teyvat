# Copy this file to .env.local and fill in your values

# LLM Provider API Keys (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# Upstash Redis — for per-IP and global daily rate limiting
# Create a free database at https://console.upstash.com
# Leave blank to disable rate limiting (useful for local dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: shown in OpenRouter's HTTP-Referer header
SITE_URL=https://your-vercel-domain.vercel.app

# Daily request cap (default: 1000)
# MAX_REQUESTS_PER_DAY=1000

# Supabase — stores questionnaire answers, bullet selections, and generated
# stories for LLM fine-tuning. Leave blank to disable telemetry (the app still
# works normally; nothing is written).
#
# For local dev, run `npm run db:start` (which calls `supabase start`) and
# copy the printed "service_role key" into SUPABASE_SERVICE_ROLE_KEY below.
# The URL is stable across every local boot.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# Agentic pipeline — optional fallback provider chain (comma-separated)
# When the primary provider returns a retryable error, the pipeline tries
# these providers in order before surfacing the failure to the user.
# NEXT_PUBLIC_FALLBACK_PROVIDERS=anthropic,xai

# Promptfoo red-team target — optional, used by `npm run redteam:run`.
# Start `npm run dev` first unless you point this at another deployment.
PROMPTFOO_TARGET_BASE_URL=http://127.0.0.1:3000
PROMPTFOO_TARGET_PROVIDER=openrouter
PROMPTFOO_TARGET_MODEL=anthropic/claude-sonnet-4.6

# Optional model overrides for `npm run eval:live` when a configured model is
# unavailable in your account or region.
PROMPTFOO_OPENROUTER_MODEL=
PROMPTFOO_DEEPSEEK_MODEL=
PROMPTFOO_XAI_MODEL=
PROMPTFOO_LIVE_TIMEOUT_MS=60000
